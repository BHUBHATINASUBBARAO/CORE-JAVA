

				SCANNER CLASS 
—-----------------------------------------------------------------------------------------------------------
Scanner class is used to read the value from the user at execution time of the programme
If we want to use the scanner class in the programme 2 statements is mandatory
Import java.util.Scanner;
 Scanner sc=new Scanner(System.in);


Int —-----> nextInt();
float—---------->nextFloat();
String—-------> next();
char—------->next().charAt(0);
Ex:-
—---
import java.util.Scanner;
class Voter_Id
{
public static void main(String []args)
{
Scanner sc=new Scanner(System.in);
System.out.println(" enter your age");
int age =sc.nextInt();
System.out.println(" enter your name");
String name=sc.next();
System.out.println("enter your surname");
char surname=sc.next().charAt(0);
if(age>18)
{
System.out.println(surname +"."+name+" you are elijible for voter id");
}
else{
System.out.println(surname+"."+name+" you are not elijable for voter id");
}
}
}


